# Streamlit Community Cloud: paste this into app Settings → Secrets (TOML format).
# For local dev: copy to .streamlit/secrets.toml (that file is gitignored).

[api]
# Your Render web service URL — no trailing slash
base_url = "https://fastapi-car-price-api-i09k.onrender.com"
# Must match the API_KEY you set on Render for the same backend
api_key = "your-strong-shared-secret"

# Optional: password gate before chat (share link publicly, password only with trusted people)
# [demo]
# password = "your-shared-demo-password"
